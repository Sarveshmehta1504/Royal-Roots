{
  "version": 2,
  "builds": [
    {
      "src": "server.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.py"
    },
    {
      "src": "/admin",
      "dest": "server.py"
    },
    {
      "src": "/login",
      "dest": "server.py"
    },
    {
      "src": "/logout",
      "dest": "server.py"
    },
    {
      "src": "/verify_token",
      "dest": "server.py"
    },
    {
      "src": "/blog/(.*)",
      "dest": "server.py"
    },
    {
      "src": "/robots.txt",
      "dest": "server.py"
    },
    {
      "src": "/sitemap.xml",
      "dest": "server.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
