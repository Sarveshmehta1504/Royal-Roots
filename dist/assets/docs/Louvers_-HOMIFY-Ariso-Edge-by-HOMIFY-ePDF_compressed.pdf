		<style id="wp-custom-css">
			@media (max-width:1024px){#ast-desktop-header{display:none;}}

#page{
	overflow:hidden;
}

/* Banner _ Icon */
@media (max-width: 426px){
.bdt-pagepiling-slider .bdt-slide-btn .bdt-button-circle .icon.arrow {
    -webkit-transition: all .45s cubic-bezier(.65, 0, .076, 1);
    transition: all .45s cubic-bezier(.65, 0, .076, 1);
    left: .425rem;
    width: 1.125rem;
    height: .125rem;
    background: none;
    margin-top: 1.8em;
}
}


/* Banner -Text */
@media (max-width: 426px) {
    .bdt-pagepiling-slider .bdt-prime-slider-content * {
    opacity: 1 !important;
    visibility: visible !important;
    transform: translateY(-12px);
    transition: all .3s;
}
}

/* Image overlay about us */

.elementor-widget-video .elementor-open-inline .elementor-custom-embed-image-overlay::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.6); /* black with 60% opacity */
    z-index: 1;
}

/* Keep the play button above the overlay */
.elementor-widget-video .elementor-open-inline .elementor-custom-embed-play {
    position: relative;
    z-index: 2;
}



/* Youtube icon */
.elementor-custom-embed-play {
    left: 0%;
    position: absolute;
    top: 50%;
    transform: translate(-50%, -50%);
}


.elementor-custom-embed-play {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
}

/* Dark Yellow Ripple */
.elementor-custom-embed-play::before,
.elementor-custom-embed-play::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    width: 60px;
    height: 60px;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    box-shadow: 0 0 0 0 rgba(255, 193, 7, 0.5); /* Dark yellow ripple */
    animation: ripple 2.5s infinite;
    z-index: -1;
}

.elementor-custom-embed-play::after {
    animation-delay: 1.2s;
}

/* Ripple Animation */
@keyframes ripple {
    0% {
        box-shadow: 0 0 0 0 rgba(255, 193, 7, 0.5);
    }
    70% {
        box-shadow: 0 0 0 25px rgba(255, 193, 7, 0);
    }
    100% {
        box-shadow: 0 0 0 0 rgba(255, 193, 7, 0);
    }
}


/* Responsive scaling */
@media (max-width: 768px) {
    .elementor-custom-embed-play::before,
    .elementor-custom-embed-play::after {
        width: 45px;
        height: 45px;
    }
}

@media (max-width: 480px) {
    .elementor-custom-embed-play::before,
    .elementor-custom-embed-play::after {
        width: 35px;
        height: 35px;
    }
}

@media (max-width: 480px) {
.elementor-custom-embed-play {
    left: 10%;
    position: absolute;
    top: 50%;
    transform: translate(-50%, -50%);
}
}
	
	
/* slider */
div#pp-nav {
    display: none;
}


@media (min-width: 1024px){
.elementor-29 .elementor-element.elementor-element-87109e4 .bdt-pagepiling-slider .bdt-prime-slider-content {
      max-width: 100% !important;
    text-align: center;
    width: 100% !important;
    padding-top: 30%;
}
}

@media (min-width: 640px) {
    .bdt-pagepiling-slider .bdt-prime-slider-content {
        padding-top:37%;
        margin-left: 230px;
    }
}


@media (max-width: 426px) {
    .bdt-pagepiling-slider .bdt-prime-slider-content {
        padding-top:62%;
        margin-left: 100px;
    }
} 


/* our products */

@media (max-width:769px){
.bdt-prime-slider {
    position: relative;
    overflow: hidden;
    margin: -7em 0px;
    z-index: 0;
}
}

@media (min-width: 1024px) {
    .elementor-29 .elementor-element.elementor-element-2efd857 > .elementor-element-populated {
         margin: 5% 0% 0% 0%;
    
    }
}

/* table */
td, th {
  padding: 7px!important
  line-height: 23px;
}
table, td, th {
  border: 1px solid #B3B3B3!important;
}

th{
	text-align:left;
	background :#826951;
	color:#fff;
}
.head-row{
	background :#000;
	color:#fff;
}

@media (max-width: 321px){
.elementor-element.elementor-element-8337504.elementor-absolute.elementor-widget.elementor-widget-eael-interactive-promo{
	margin-top:-35%;}
